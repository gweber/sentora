# =============================================================================
# Sentora — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# See docs/deployment/environment-variables.md for full documentation.
# =============================================================================


# =============================================================================
# SentinelOne Integration [REQUIRED]
# =============================================================================

# Your SentinelOne management console URL (no trailing slash).
# Example: https://usea1.sentinelone.net
S1_BASE_URL=https://your-instance.sentinelone.net

# API token with Viewer scope at Account level.
# See docs/guides/s1-api-setup.md for step-by-step token creation.
# ⚠ NEVER commit a real token. This file is .gitignored.
S1_API_TOKEN=your-api-token-here

# Maximum S1 API requests per minute (S1 default limit is 100).
S1_RATE_LIMIT_PER_MINUTE=100


# =============================================================================
# MongoDB
# =============================================================================

# Connection string. Use mongodb://mongo:27017 in Docker Compose.
MONGO_URI=mongodb://localhost:27017

# Database name (a separate test DB is created automatically during tests).
MONGO_DB=sentora


# =============================================================================
# MongoDB High Availability (Optional)
# =============================================================================
# For replica set deployments. See docs/deployment/high-availability.md

# Read preference: primary | primaryPreferred | secondaryPreferred | secondary | nearest
# MONGO_READ_PREFERENCE=primary

# Write concern: "majority" or a number (e.g. "1", "2")
# MONGO_WRITE_CONCERN_W=majority

# Require journal acknowledgement for writes (true | false).
# MONGO_WRITE_CONCERN_J=true

# Connection pool sizing (tune based on expected concurrent connections).
# MONGO_MAX_POOL_SIZE=100
# MONGO_MIN_POOL_SIZE=0
# MONGO_MAX_IDLE_TIME_MS=30000


# =============================================================================
# Deployment Mode
# =============================================================================
# Controls how the application is deployed and who has access to platform features.
#
# onprem  — Single-tenant on-premises. Admin is the top role.
#            No tenant management, library sources accessible to admin.
# saas    — Multi-tenant SaaS. Super-admin manages the platform.
#            Tenants are isolated by database, super_admin manages sources.
DEPLOYMENT_MODE=onprem


# =============================================================================
# Multi-Tenancy (SaaS mode only)
# =============================================================================
# When DEPLOYMENT_MODE=saas, these settings control tenant isolation.
# In on-prem mode, multi-tenancy is ignored.

# Enable database-per-tenant isolation.
MULTI_TENANCY_ENABLED=false

# Tenant isolation strategy (only "database" is supported).
# TENANT_ISOLATION=database

# Master database for tenant registry and shared data (library entries, etc.).
# MASTER_DB_NAME=sentora_master


# =============================================================================
# JWT Authentication
# =============================================================================

# Secret key for signing JWT tokens. [REQUIRED] in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# If empty, a random key is generated on each startup (tokens won't survive restarts).
JWT_SECRET_KEY=

# Access token lifetime in minutes (default: 15).
JWT_ACCESS_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7).
JWT_REFRESH_EXPIRE_DAYS=7

# Separate key for field-level encryption (webhook secrets, API keys, etc.).
# Falls back to JWT_SECRET_KEY if empty. Set a dedicated key for better security.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
FIELD_ENCRYPTION_KEY=


# =============================================================================
# Session & Account Security (ADR-0021)
# =============================================================================

# Maximum absolute session lifetime in days. Sessions expire after this period.
SESSION_MAX_LIFETIME_DAYS=30

# Session inactivity timeout in days.
SESSION_INACTIVITY_TIMEOUT_DAYS=30

# Failed login attempts before account lockout.
ACCOUNT_LOCKOUT_THRESHOLD=5

# Account lockout duration in minutes.
ACCOUNT_LOCKOUT_DURATION_MINUTES=15


# =============================================================================
# Password Policy (NIST SP 800-63B)
# =============================================================================

# Minimum password length (NIST recommends >= 8, we default to 12).
PASSWORD_MIN_LENGTH=12

# Character class requirements.
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Number of previous passwords to remember (0 to disable).
PASSWORD_HISTORY_COUNT=5

# Password expiry in days (0 = no expiry, NIST-compliant default).
PASSWORD_MAX_AGE_DAYS=0

# Check new passwords against HaveIBeenPwned breach database.
# Uses k-Anonymity API — the password never leaves the server.
# Set to false to disable external API calls.
PASSWORD_CHECK_BREACHED=true


# =============================================================================
# Application
# =============================================================================

# Port the uvicorn server listens on.
APP_PORT=5002

# Environment: development | staging | production
# Controls Swagger UI availability, CORS origins, and log verbosity.
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# =============================================================================
# Classification Engine Tuning
# =============================================================================
# These defaults work well for most environments.
# Adjust after reviewing your first classification results.

# Minimum match score (0.0–1.0) for an agent to be classified as "correct".
CLASSIFICATION_THRESHOLD=0.6

# If the top two group scores are within this gap, classify as "ambiguous".
AMBIGUITY_GAP=0.15

# Apps present in more than this fraction of ALL agents are excluded from
# fingerprint suggestions (they're too common to be informative).
UNIVERSAL_APP_THRESHOLD=0.6

# Minimum TF-IDF-like score for a statistical suggestion to appear.
SUGGESTION_SCORE_THRESHOLD=0.5


# =============================================================================
# OIDC / SSO (Optional)
# =============================================================================
# Enable OpenID Connect for enterprise SSO (Azure AD, Okta, Google Workspace, etc.)

OIDC_ENABLED=false
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5002/api/v1/auth/oidc/callback
OIDC_DEFAULT_ROLE=viewer


# =============================================================================
# SAML SSO (Optional)
# =============================================================================
# Enable SAML 2.0 for enterprise SSO (ADFS, Okta, OneLogin, etc.)

SAML_ENABLED=false
SAML_IDP_METADATA_URL=
SAML_SP_ENTITY_ID=
SAML_SP_ACS_URL=http://localhost:5002/api/v1/auth/saml/callback
# SP certificate and private key (PEM string or file path).
SAML_SP_CERT=
SAML_SP_KEY=
SAML_DEFAULT_ROLE=viewer


# =============================================================================
# OpenTelemetry / Distributed Tracing
# =============================================================================
# Enable Jaeger tracing: `docker compose --profile tracing up`
# then set OTEL_ENABLED=true to start exporting traces.

# Enable OpenTelemetry distributed tracing (true | false).
OTEL_ENABLED=false

# Service name reported in traces.
OTEL_SERVICE_NAME=sentora

# OTLP gRPC collector endpoint. Use http://jaeger:4317 in Docker Compose.
OTEL_ENDPOINT=http://localhost:4317


# =============================================================================
# Rate Limiting
# =============================================================================

# Maximum inbound API requests per minute per IP address.
RATE_LIMIT_PER_MINUTE=100


# =============================================================================
# Fingerprint Library Ingestion
# =============================================================================

# Enable background ingestion from public sources (NIST CPE, MITRE, etc.).
# Sources are configured via the Library Sources admin view.
LIBRARY_INGESTION_ENABLED=false

# Hours between automatic ingestion runs (1–168, default 24).
LIBRARY_INGESTION_INTERVAL_HOURS=24

# Comma-separated list of enabled source adapters.
# Available: nist_cpe, mitre, chocolatey, homebrew
LIBRARY_INGESTION_SOURCES=


# =============================================================================
# Multi-Worker
# =============================================================================

# Use MongoDB distributed advisory locks for cross-worker protection.
# Set to false to use asyncio.Lock only (single-worker backward compatibility).
ENABLE_DISTRIBUTED_LOCKS=true

# Number of uvicorn workers (default: 1 for backward compatibility).
# Multi-worker requires ENABLE_DISTRIBUTED_LOCKS=true.
WORKERS=1


# =============================================================================
# Backup / Restore
# =============================================================================
# Enable automated MongoDB backups.
# Requires mongodump/mongorestore in PATH (installed via mongodb-database-tools).

# Enable scheduled backups (true | false).
BACKUP_ENABLED=false

# Local directory for backup storage.
BACKUP_LOCAL_PATH=/backups

# Number of backups to retain (oldest are deleted when exceeded).
BACKUP_RETENTION_COUNT=7

# Cron schedule for automated backups (default: daily at 2 AM UTC).
BACKUP_SCHEDULE_CRON=0 2 * * *
